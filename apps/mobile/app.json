{
  "expo": {
    "name": "GymApp",
    "slug": "gymapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f12"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gymapp.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para escanear el QR de acceso y fotografiar productos.",
        "NSFaceIDUsageDescription": "Usa Face ID para autenticarte rápidamente.",
        "NFCReaderUsageDescription": "Usa NFC para acceso al gym con tu tarjeta o pulsera.",
        "NSPhotoLibraryUsageDescription": "Permite seleccionar una foto de tu galería para tu avatar de perfil.",
        "NSHealthShareUsageDescription": "Permite a GymApp leer tu peso, agua y sueño de Salud para sincronizar tu progreso nutricional automáticamente."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.gymapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f12"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_HYDRATION",
        "android.permission.health.READ_SLEEP"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permite a GymApp usar Face ID para autenticarte."
        }
      ],
      "@kingstinct/react-native-healthkit",
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "scheme": "gymapp",
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/5853d764-b3de-4bfe-9e87-78ddb0c8dfe3"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "5853d764-b3de-4bfe-9e87-78ddb0c8dfe3"
      }
    }
  }
}
