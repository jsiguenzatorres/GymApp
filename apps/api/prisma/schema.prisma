// GymApp — Prisma Schema
// Fase 0: tablas base (gyms, users, staff, members)
// Las tablas de negocio se agregan en los sprints de Fase 1+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  GYM_OWNER
  GYM_ADMIN
  TRAINER
  RECEPTIONIST
  NUTRITIONIST
  MEMBER
  MEMBER_TRIAL
}

enum MemberStatus {
  LEAD
  TRIAL
  ACTIVE
  FREEZE
  EXPIRED
  PRE_CANCEL
  CANCELLED
}

enum SaasPlan {
  STARTER
  PRO
  ELITE
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum BillingFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum MembershipStatus {
  TRIAL
  ACTIVE
  FROZEN
  EXPIRED
  CANCELLED
}

// ─── GYMS ────────────────────────────────────────────────────────────────────

model Gym {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(100)
  logo_url    String?
  saas_plan   SaasPlan @default(STARTER)
  is_active   Boolean  @default(true)
  // Configuración regional
  timezone    String   @default("America/El_Salvador") @db.VarChar(50)
  country     String   @default("SV") @db.VarChar(2)
  currency    String   @default("USD") @db.VarChar(3)
  // Contacto
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(150)
  address     String?
  website     String?
  // Fiscal (para DTE El Salvador)
  tax_id      String?  @db.VarChar(20)  // NIT/RUC
  legal_name  String?  @db.VarChar(200)
  // Metadata
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relaciones
  staff            Staff[]
  members          Member[]
  membership_types MembershipType[]
  memberships      Membership[]
  payment_methods  PaymentMethod[]
  payments         Payment[]

  @@index([saas_plan, is_active])
  @@map("gyms")
}

// ─── USERS (capa de autenticación) ──────────────────────────────────────────

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String    @unique @db.VarChar(150)
  password_hash       String
  role                UserRole
  is_active           Boolean   @default(true)
  email_verified      Boolean   @default(false)
  email_verified_at   DateTime?
  // 2FA
  two_fa_enabled      Boolean   @default(false)
  two_fa_secret       String?   // encriptado en reposo
  two_fa_backup_codes String[]  // hashed
  // Sesión
  last_login_at       DateTime?
  last_login_ip       String?   @db.VarChar(45)
  refresh_token_hash  String?   // para invalidar sesiones
  // Password reset
  reset_token_hash    String?
  reset_token_exp     DateTime?
  // Metadata
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  staff  Staff?
  member Member?

  @@index([email, is_active])
  @@map("users")
}

// ─── STAFF (empleados del gym) ───────────────────────────────────────────────

model Staff {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  user_id      String   @unique @db.Uuid
  first_name   String   @db.VarChar(100)
  last_name    String   @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  avatar_url   String?
  bio          String?
  specialties  String[] // para trainers: ["fuerza", "cardio", "yoga"]
  is_active    Boolean  @default(true)
  hired_at     DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  gym  Gym  @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([gym_id, is_active])
  @@map("staff")
}

// ─── MEMBERS (miembros del gym) ──────────────────────────────────────────────

model Member {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String       @db.Uuid
  user_id       String       @unique @db.Uuid
  first_name    String       @db.VarChar(100)
  last_name     String       @db.VarChar(100)
  phone         String?      @db.VarChar(20)
  birthdate     DateTime?    @db.Date
  gender        String?      @db.VarChar(10) // M|F|X
  avatar_url    String?
  // Estado del ciclo de vida
  status        MemberStatus @default(LEAD)
  // CRM
  risk_score    Int          @default(0) // 0-100
  loyalty_level String       @default("bronze") @db.VarChar(20)
  // Metadata
  referred_by   String?      @db.Uuid
  source        String?      @db.VarChar(50) // walk-in|referral|social_media|web
  notes         String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  gym             Gym             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  memberships     Membership[]
  payment_methods PaymentMethod[]
  payments        Payment[]

  @@index([gym_id, status])
  @@index([gym_id, risk_score])
  @@index([gym_id, created_at(sort: Desc)])
  @@map("members")
}

// ─── MEMBERSHIP TYPES (catálogo de planes) ───────────────────────────────────

model MembershipType {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String           @db.Uuid
  name              String           @db.VarChar(150)
  description       String?
  price             Decimal          @db.Decimal(10, 2)
  currency          String           @default("USD") @db.VarChar(3)
  billing_frequency BillingFrequency @default(MONTHLY)
  duration_days     Int
  max_freezes       Int              @default(1)
  max_freeze_days   Int              @default(30)
  features          String[]
  is_active         Boolean          @default(true)
  is_trial          Boolean          @default(false)
  sort_order        Int              @default(0)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  gym         Gym          @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@index([gym_id, is_active])
  @@index([gym_id, sort_order])
  @@map("membership_types")
}

// ─── MEMBERSHIPS (suscripciones activas e historial) ─────────────────────────

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String           @db.Uuid
  member_id      String           @db.Uuid
  type_id        String           @db.Uuid
  status         MembershipStatus @default(TRIAL)
  start_date     DateTime         @db.Date
  end_date       DateTime         @db.Date
  price_paid     Decimal          @db.Decimal(10, 2)
  currency       String           @default("USD") @db.VarChar(3)
  // Congelación
  freeze_count   Int              @default(0)
  frozen_at      DateTime?
  freeze_ends_at DateTime?
  // Cancelación
  cancelled_at   DateTime?
  cancel_reason  String?
  // Notas
  notes          String?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  gym      Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  type     MembershipType @relation(fields: [type_id], references: [id])
  payments Payment[]

  @@index([gym_id, status])
  @@index([gym_id, member_id])
  @@index([gym_id, end_date])
  @@map("memberships")
}

// ─── PAYMENT METHODS (tokens de gateway — NUNCA números de tarjeta) ──────────

model PaymentMethod {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  member_id     String   @db.Uuid
  gateway       String   @db.VarChar(30)  // stripe | mercadopago
  gateway_token String   @db.VarChar(200) // token del gateway
  last_four     String?  @db.VarChar(4)
  card_brand    String?  @db.VarChar(20)
  exp_month     Int?
  exp_year      Int?
  is_default    Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  gym      Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([gym_id, member_id, is_active])
  @@map("payment_methods")
}

// ─── PAYMENTS (transacciones de cobro) ───────────────────────────────────────

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String        @db.Uuid
  member_id         String        @db.Uuid
  membership_id     String?       @db.Uuid
  payment_method_id String?       @db.Uuid

  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD") @db.VarChar(3)
  status            PaymentStatus @default(PENDING)
  payment_type      String        @db.VarChar(30) // CASH|CARD|BANK_TRANSFER|STRIPE|MERCADOPAGO|OTHER

  // Datos del gateway (cuando aplica)
  gateway_payment_id String?      @db.VarChar(200)
  gateway_status     String?      @db.VarChar(50)

  // Facturación DTE El Salvador
  invoice_type       String?      @db.VarChar(5)   // CF|CCF
  dte_codigo         String?      @db.VarChar(100)
  dte_numero_control String?      @db.VarChar(100)
  dte_sello          String?      @db.VarChar(200)

  // Reintentos (dunning)
  attempt_number    Int           @default(1)
  next_retry_at     DateTime?

  description       String?
  notes             String?
  paid_at           DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  gym            Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member         Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  membership     Membership?    @relation(fields: [membership_id], references: [id])
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])

  @@index([gym_id, status])
  @@index([gym_id, member_id])
  @@index([gym_id, created_at(sort: Desc)])
  @@index([gym_id, paid_at])
  @@map("payments")
}
