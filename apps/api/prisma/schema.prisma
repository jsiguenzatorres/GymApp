// GymApp — Prisma Schema
// Fase 0: tablas base (gyms, users, staff, members)
// Las tablas de negocio se agregan en los sprints de Fase 1+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  GYM_OWNER
  GYM_ADMIN
  TRAINER
  RECEPTIONIST
  NUTRITIONIST
  MEMBER
  MEMBER_TRIAL
}

enum MemberStatus {
  LEAD
  TRIAL
  ACTIVE
  FREEZE
  EXPIRED
  PRE_CANCEL
  CANCELLED
}

enum SaasPlan {
  STARTER
  PRO
  ELITE
  ENTERPRISE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum BillingFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum MembershipStatus {
  TRIAL
  ACTIVE
  FROZEN
  EXPIRED
  CANCELLED
}

// ─── GYMS ────────────────────────────────────────────────────────────────────

model Gym {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(100)
  logo_url    String?
  saas_plan   SaasPlan @default(STARTER)
  is_active   Boolean  @default(true)
  // Configuración regional
  timezone    String   @default("America/El_Salvador") @db.VarChar(50)
  country     String   @default("SV") @db.VarChar(2)
  currency    String   @default("USD") @db.VarChar(3)
  // Descripción y ubicación
  description String?
  city        String?  @db.VarChar(100)
  // Contacto
  phone       String?  @db.VarChar(20)
  email       String?  @db.VarChar(150)
  address     String?
  website     String?
  // Redes sociales {instagram, facebook, whatsapp, tiktok}
  social_links Json    @default("{}")
  // Horarios de operación {mon:{open:"06:00",close:"22:00",closed:false}, ...}
  operating_hours Json @default("{}")
  // Fiscal (para DTE El Salvador)
  tax_id      String?  @db.VarChar(20)  // NIT/RUC
  legal_name  String?  @db.VarChar(200)
  // Metadata
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relaciones
  staff            Staff[]
  members          Member[]
  membership_types MembershipType[]
  memberships      Membership[]
  payment_methods  PaymentMethod[]
  payments         Payment[]
  exercises        Exercise[]
  workout_plans    WorkoutPlan[]
  member_plans     MemberPlan[]
  workout_sessions WorkoutSession[]
  personal_records PersonalRecord[]
  crm_interactions CrmInteraction[]
  appointments     Appointment[]
  metric_snapshots    MetricSnapshot[]
  access_logs         AccessLog[]
  notifications       Notification[]
  product_categories  ProductCategory[]
  products            Product[]
  marketplace_orders  MarketplaceOrder[]
  nutrition_plans     NutritionPlan[]
  food_items          FoodItem[]
  food_diary_entries  FoodDiaryEntry[]
  class_types         ClassType[]
  class_sessions      ClassSession[]
  class_enrollments   ClassEnrollment[]
  points_transactions PointsTransaction[]
  badges              Badge[]
  member_badges       MemberBadge[]

  @@index([saas_plan, is_active])
  @@map("gyms")
}

// ─── USERS (capa de autenticación) ──────────────────────────────────────────

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String    @unique @db.VarChar(150)
  password_hash       String
  role                UserRole
  is_active           Boolean   @default(true)
  email_verified      Boolean   @default(false)
  email_verified_at   DateTime?
  // 2FA
  two_fa_enabled      Boolean   @default(false)
  two_fa_secret       String?   // encriptado en reposo
  two_fa_backup_codes String[]  // hashed
  // Sesión
  last_login_at       DateTime?
  last_login_ip       String?   @db.VarChar(45)
  refresh_token_hash  String?   // para invalidar sesiones
  // Password reset
  reset_token_hash    String?
  reset_token_exp     DateTime?
  // Metadata
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  staff         Staff?
  member        Member?
  notifications Notification[]
  device_tokens DeviceToken[]

  @@index([email, is_active])
  @@map("users")
}

model DeviceToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique @db.VarChar(255)
  platform   String   @db.VarChar(10)  // ios | android
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("device_tokens")
}

// ─── STAFF (empleados del gym) ───────────────────────────────────────────────

model Staff {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  user_id      String   @unique @db.Uuid
  first_name   String   @db.VarChar(100)
  last_name    String   @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  avatar_url   String?
  bio          String?
  specialties  String[] // para trainers: ["fuerza", "cardio", "yoga"]
  is_active    Boolean  @default(true)
  hired_at     DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  gym              Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  crm_interactions CrmInteraction[]
  appointments     Appointment[]
  class_sessions   ClassSession[]

  @@index([gym_id, is_active])
  @@map("staff")
}

// ─── MEMBERS (miembros del gym) ──────────────────────────────────────────────

model Member {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String       @db.Uuid
  user_id       String       @unique @db.Uuid
  first_name    String       @db.VarChar(100)
  last_name     String       @db.VarChar(100)
  phone         String?      @db.VarChar(20)
  birthdate     DateTime?    @db.Date
  gender        String?      @db.VarChar(10) // M|F|X
  avatar_url    String?
  // Estado del ciclo de vida
  status        MemberStatus @default(LEAD)
  // CRM
  risk_score            Int       @default(0) // 0-100
  risk_score_updated_at DateTime?
  loyalty_level         String    @default("bronze") @db.VarChar(20)
  // Gamificación
  points_lifetime       Int       @default(0) // FitCoins acumulados históricamente (nivel)
  points_balance        Int       @default(0) // FitCoins disponibles (gastables)
  // Metadata
  referred_by   String?      @db.Uuid
  source        String?      @db.VarChar(50) // walk-in|referral|social_media|web
  notes         String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  gym              Gym             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  memberships      Membership[]
  payment_methods  PaymentMethod[]
  payments         Payment[]
  member_plans     MemberPlan[]
  workout_sessions WorkoutSession[]
  personal_records PersonalRecord[]
  crm_interactions   CrmInteraction[]
  appointments       Appointment[]
  access_logs        AccessLog[]
  marketplace_orders MarketplaceOrder[]
  nutrition_plans    NutritionPlan[]
  food_diary_entries FoodDiaryEntry[]
  class_enrollments   ClassEnrollment[]
  points_transactions PointsTransaction[]
  member_badges       MemberBadge[]

  @@index([gym_id, status])
  @@index([gym_id, risk_score])
  @@index([gym_id, points_lifetime(sort: Desc)])
  @@index([gym_id, created_at(sort: Desc)])
  @@map("members")
}

// ─── MEMBERSHIP TYPES (catálogo de planes) ───────────────────────────────────

model MembershipType {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String           @db.Uuid
  name              String           @db.VarChar(150)
  description       String?
  price             Decimal          @db.Decimal(10, 2)
  currency          String           @default("USD") @db.VarChar(3)
  billing_frequency BillingFrequency @default(MONTHLY)
  duration_days     Int
  max_freezes       Int              @default(1)
  max_freeze_days   Int              @default(30)
  features          String[]
  is_active         Boolean          @default(true)
  is_trial          Boolean          @default(false)
  sort_order        Int              @default(0)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  gym         Gym          @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@index([gym_id, is_active])
  @@index([gym_id, sort_order])
  @@map("membership_types")
}

// ─── MEMBERSHIPS (suscripciones activas e historial) ─────────────────────────

model Membership {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id         String           @db.Uuid
  member_id      String           @db.Uuid
  type_id        String           @db.Uuid
  status         MembershipStatus @default(TRIAL)
  start_date     DateTime         @db.Date
  end_date       DateTime         @db.Date
  price_paid     Decimal          @db.Decimal(10, 2)
  currency       String           @default("USD") @db.VarChar(3)
  // Congelación
  freeze_count   Int              @default(0)
  frozen_at      DateTime?
  freeze_ends_at DateTime?
  // Cancelación
  cancelled_at   DateTime?
  cancel_reason  String?
  // Notas
  notes          String?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  gym      Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  type     MembershipType @relation(fields: [type_id], references: [id])
  payments Payment[]

  @@index([gym_id, status])
  @@index([gym_id, member_id])
  @@index([gym_id, end_date])
  @@map("memberships")
}

// ─── PAYMENT METHODS (tokens de gateway — NUNCA números de tarjeta) ──────────

model PaymentMethod {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  member_id     String   @db.Uuid
  gateway       String   @db.VarChar(30)  // stripe | mercadopago
  gateway_token String   @db.VarChar(200) // token del gateway
  last_four     String?  @db.VarChar(4)
  card_brand    String?  @db.VarChar(20)
  exp_month     Int?
  exp_year      Int?
  is_default    Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  gym      Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([gym_id, member_id, is_active])
  @@map("payment_methods")
}

// ─── PAYMENTS (transacciones de cobro) ───────────────────────────────────────

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String        @db.Uuid
  member_id         String        @db.Uuid
  membership_id     String?       @db.Uuid
  payment_method_id String?       @db.Uuid

  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("USD") @db.VarChar(3)
  status            PaymentStatus @default(PENDING)
  payment_type      String        @db.VarChar(30) // CASH|CARD|BANK_TRANSFER|STRIPE|MERCADOPAGO|OTHER

  // Datos del gateway (cuando aplica)
  gateway_payment_id String?      @db.VarChar(200)
  gateway_status     String?      @db.VarChar(50)

  // Facturación DTE El Salvador
  invoice_type       String?      @db.VarChar(5)   // CF|CCF
  dte_codigo         String?      @db.VarChar(100)
  dte_numero_control String?      @db.VarChar(100)
  dte_sello          String?      @db.VarChar(200)

  // Reintentos (dunning)
  attempt_number    Int           @default(1)
  next_retry_at     DateTime?

  description       String?
  notes             String?
  paid_at           DateTime?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  gym            Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member         Member         @relation(fields: [member_id], references: [id], onDelete: Cascade)
  membership     Membership?    @relation(fields: [membership_id], references: [id])
  payment_method PaymentMethod? @relation(fields: [payment_method_id], references: [id])

  @@index([gym_id, status])
  @@index([gym_id, member_id])
  @@index([gym_id, created_at(sort: Desc)])
  @@index([gym_id, paid_at])
  @@map("payments")
}

// ─── EXERCISES (biblioteca de ejercicios) ────────────────────────────────────

model Exercise {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id            String?  @db.Uuid   // null = ejercicio global/built-in
  name              String   @db.VarChar(200)
  description       String?
  muscle_groups     String[] // músculos primarios
  secondary_muscles String[] // músculos secundarios
  equipment         String[]
  category          String   @default("STRENGTH") @db.VarChar(30)
  difficulty        String   @default("INTERMEDIATE") @db.VarChar(20)
  instructions      String?
  video_url         String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  gym              Gym?             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  workout_blocks   WorkoutBlock[]
  workout_sets     WorkoutSet[]
  personal_records PersonalRecord[]

  @@index([gym_id])
  @@index([category, is_active])
  @@map("exercises")
}

// ─── WORKOUT PLANS (plantillas de entrenamiento) ─────────────────────────────

model WorkoutPlan {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id        String   @db.Uuid
  name          String   @db.VarChar(200)
  description   String?
  goal          String?  @db.VarChar(30)
  difficulty    String   @default("INTERMEDIATE") @db.VarChar(20)
  days_per_week Int      @default(3)
  is_active     Boolean  @default(true)
  is_template   Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  gym          Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  days         WorkoutPlanDay[]
  member_plans MemberPlan[]
  sessions     WorkoutSession[]

  @@index([gym_id, is_active])
  @@map("workout_plans")
}

model WorkoutPlanDay {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plan_id    String   @db.Uuid
  day_number Int
  name       String?  @db.VarChar(100)

  plan     WorkoutPlan     @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  blocks   WorkoutBlock[]
  sessions WorkoutSession[]

  @@index([plan_id, day_number])
  @@map("workout_plan_days")
}

model WorkoutBlock {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  day_id       String   @db.Uuid
  exercise_id  String   @db.Uuid
  block_type   String   @default("STANDARD") @db.VarChar(20)
  order        Int
  sets         Int      @default(3)
  reps_min     Int?
  reps_max     Int?
  rpe          Float?
  rest_seconds Int?
  notes        String?

  day      WorkoutPlanDay @relation(fields: [day_id], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exercise_id], references: [id])

  @@index([day_id, order])
  @@map("workout_blocks")
}

// ─── MEMBER PLANS (asignación plan → miembro) ────────────────────────────────

model MemberPlan {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  member_id  String   @db.Uuid
  plan_id    String   @db.Uuid
  is_active  Boolean  @default(true)
  started_at DateTime @default(now())
  notes      String?

  gym    Gym         @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member      @relation(fields: [member_id], references: [id], onDelete: Cascade)
  plan   WorkoutPlan @relation(fields: [plan_id], references: [id])

  @@index([gym_id, member_id, is_active])
  @@map("member_plans")
}

// ─── WORKOUT SESSIONS (sesiones de entrenamiento) ────────────────────────────

model WorkoutSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String    @db.Uuid
  member_id        String    @db.Uuid
  plan_id          String?   @db.Uuid
  plan_day_id      String?   @db.Uuid
  name             String?   @db.VarChar(200)
  started_at       DateTime  @default(now())
  finished_at      DateTime?
  duration_min     Int?
  notes            String?
  perceived_effort Int?
  created_at       DateTime  @default(now())

  gym      Gym             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member          @relation(fields: [member_id], references: [id], onDelete: Cascade)
  plan     WorkoutPlan?    @relation(fields: [plan_id], references: [id])
  plan_day WorkoutPlanDay? @relation(fields: [plan_day_id], references: [id])
  sets     WorkoutSet[]

  @@index([gym_id, member_id])
  @@index([gym_id, started_at(sort: Desc)])
  @@map("workout_sessions")
}

// ─── WORKOUT SETS (series registradas en sesión) ─────────────────────────────

model WorkoutSet {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id   String   @db.Uuid
  exercise_id  String   @db.Uuid
  set_number   Int
  reps         Int?
  weight_kg    Decimal? @db.Decimal(6, 2)
  duration_sec Int?
  distance_m   Float?
  is_warmup    Boolean  @default(false)
  is_pr        Boolean  @default(false)
  notes        String?
  created_at   DateTime @default(now())

  session  WorkoutSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exercise_id], references: [id])

  @@index([session_id, exercise_id])
  @@map("workout_sets")
}

// ─── PERSONAL RECORDS ────────────────────────────────────────────────────────

model PersonalRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String   @db.Uuid
  member_id   String   @db.Uuid
  exercise_id String   @db.Uuid
  record_type String   @db.VarChar(20) // MAX_WEIGHT | MAX_REPS | BEST_TIME
  value       Decimal  @db.Decimal(8, 2)
  unit        String   @db.VarChar(10) // kg | reps | seconds
  achieved_at DateTime
  session_id  String?  @db.Uuid
  created_at  DateTime @default(now())

  gym      Gym      @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member   Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exercise_id], references: [id])

  @@unique([gym_id, member_id, exercise_id, record_type])
  @@index([gym_id, member_id])
  @@map("personal_records")
}

// ─── CRM INTERACTIONS (historial de interacciones con miembros) ───────────────

model CrmInteraction {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String    @db.Uuid
  member_id        String    @db.Uuid
  staff_id         String?   @db.Uuid
  interaction_type String    @db.VarChar(30) // CALL|MESSAGE|VISIT|NOTE|COMPLAINT|EMAIL|APPOINTMENT
  channel          String?   @db.VarChar(30) // WHATSAPP|PHONE|EMAIL|IN_PERSON|APP|TELEGRAM
  subject          String?   @db.VarChar(200)
  notes            String?
  sentiment        String?   @db.VarChar(10) // POSITIVE|NEUTRAL|NEGATIVE
  outcome          String?   @db.VarChar(30) // RESOLVED|PENDING|FOLLOW_UP
  follow_up_at     DateTime?
  occurred_at      DateTime  @default(now())
  created_at       DateTime  @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)
  staff  Staff? @relation(fields: [staff_id], references: [id])

  @@index([gym_id, member_id])
  @@index([gym_id, occurred_at(sort: Desc)])
  @@map("crm_interactions")
}

// ─── APPOINTMENTS (citas agendadas) ──────────────────────────────────────────

model Appointment {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String    @db.Uuid
  member_id        String    @db.Uuid
  staff_id         String?   @db.Uuid
  title            String    @db.VarChar(200)
  description      String?
  appointment_type String    @default("CONSULTATION") @db.VarChar(30)
  status           String    @default("SCHEDULED") @db.VarChar(20)
  scheduled_at     DateTime
  duration_min     Int       @default(60)
  notes            String?
  cancelled_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)
  staff  Staff? @relation(fields: [staff_id], references: [id])

  @@index([gym_id, scheduled_at])
  @@index([gym_id, member_id])
  @@index([gym_id, status])
  @@map("appointments")
}

// ─── METRIC SNAPSHOTS (para histórico de KPIs) ───────────────────────────────

model MetricSnapshot {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  date       DateTime @db.Date
  metric_key String   @db.VarChar(50)
  value      Decimal  @db.Decimal(14, 2)
  created_at DateTime @default(now())

  gym Gym @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@unique([gym_id, date, metric_key])
  @@index([gym_id, date(sort: Desc)])
  @@map("metric_snapshots")
}

// ─── ACCESS LOGS (registro de entradas/salidas) ───────────────────────────────

model AccessLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String    @db.Uuid
  member_id   String?   @db.Uuid
  result      String    @db.VarChar(30) // GRANTED | DENIED_EXPIRED | DENIED_INVALID | DENIED_INACTIVE | DENIED_NO_MEMBERSHIP
  method      String    @default("QR") @db.VarChar(20) // QR | NFC | FACE | MANUAL
  nonce       String?   @db.VarChar(64)
  device_id   String?   @db.VarChar(100)
  notes       String?
  occurred_at DateTime  @default(now())

  gym    Gym     @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [member_id], references: [id])

  @@index([gym_id, occurred_at(sort: Desc)])
  @@index([gym_id, member_id])
  @@index([gym_id, result])
  @@map("access_logs")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String    @db.Uuid
  user_id    String    @db.Uuid
  type       String    @db.VarChar(60)    // GymEvent value, e.g. "payment.failed"
  title      String    @db.VarChar(200)
  body       String
  data       Json      @default("{}")     // payload extra (memberId, amount, etc.)
  channel    String    @default("IN_APP") @db.VarChar(20) // IN_APP | EMAIL
  is_read    Boolean   @default(false)
  read_at    DateTime?
  created_at DateTime  @default(now())

  gym  Gym  @relation(fields: [gym_id],  references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read, created_at(sort: Desc)])
  @@index([gym_id, created_at(sort: Desc)])
  @@map("notifications")
}

// ─── MARKETPLACE ──────────────────────────────────────────────────────────────

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String   @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  image_url   String?
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  gym      Gym       @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  products Product[]

  @@index([gym_id, sort_order])
  @@map("product_categories")
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String   @db.Uuid
  category_id String?  @db.Uuid
  name        String   @db.VarChar(200)
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  sku         String?  @db.VarChar(50)
  image_url   String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  gym         Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  category    ProductCategory? @relation(fields: [category_id], references: [id])
  order_items OrderItem[]

  @@index([gym_id, is_active])
  @@index([gym_id, category_id])
  @@map("products")
}

model MarketplaceOrder {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  member_id  String   @db.Uuid
  status     String   @default("PENDING") @db.VarChar(20) // PENDING|CONFIRMED|READY|DELIVERED|CANCELLED
  total      Decimal  @db.Decimal(10, 2)
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  gym    Gym         @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member      @relation(fields: [member_id], references: [id])
  items  OrderItem[]

  @@index([gym_id, status])
  @@index([gym_id, member_id])
  @@index([gym_id, created_at(sort: Desc)])
  @@map("marketplace_orders")
}

model OrderItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int
  unit_price Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)

  order   MarketplaceOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

// ─── NUTRICIÓN ────────────────────────────────────────────────────────────────

model NutritionPlan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  name         String   @db.VarChar(200)
  goal         String   @default("MAINTENANCE") @db.VarChar(30) // WEIGHT_LOSS|MUSCLE_GAIN|MAINTENANCE|PERFORMANCE
  kcal_target  Int
  protein_g    Int
  carbs_g      Int
  fat_g        Int
  notes        String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  gym             Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member          Member           @relation(fields: [member_id], references: [id])
  food_diary_entries FoodDiaryEntry[]

  @@index([gym_id, member_id])
  @@index([gym_id, is_active])
  @@map("nutrition_plans")
}

model FoodItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String? @db.Uuid  // null = item global de la biblioteca
  name            String  @db.VarChar(200)
  brand           String? @db.VarChar(100)
  kcal_per_100g   Float
  protein_per_100g Float
  carbs_per_100g  Float
  fat_per_100g    Float
  is_verified     Boolean @default(false)
  created_at      DateTime @default(now())

  gym               Gym?             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  food_diary_entries FoodDiaryEntry[]

  @@index([gym_id])
  @@map("food_items")
}

model FoodDiaryEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  plan_id      String?  @db.Uuid
  food_item_id String   @db.Uuid
  date         DateTime @db.Date
  meal_type    String   @default("LUNCH") @db.VarChar(20) // BREAKFAST|LUNCH|DINNER|SNACK
  quantity_g   Float
  kcal         Float
  protein_g    Float
  carbs_g      Float
  fat_g        Float
  notes        String?
  created_at   DateTime @default(now())

  gym       Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member    Member         @relation(fields: [member_id], references: [id])
  plan      NutritionPlan? @relation(fields: [plan_id], references: [id])
  food_item FoodItem       @relation(fields: [food_item_id], references: [id])

  @@index([gym_id, member_id, date(sort: Desc)])
  @@index([gym_id, plan_id])
  @@map("food_diary_entries")
}

// ─── Schedule / Classes ────────────────────────────────────────────────────────

model ClassType {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String         @db.Uuid
  name             String
  description      String?
  color            String         @default("#1d4ed8")
  duration_minutes Int            @default(60)
  difficulty       String?
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())

  gym      Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([gym_id])
  @@map("class_types")
}

model ClassSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String    @db.Uuid
  class_type_id    String    @db.Uuid
  trainer_id       String?   @db.Uuid
  scheduled_at     DateTime
  duration_minutes Int
  capacity         Int       @default(20)
  room             String?
  notes            String?
  status           String    @default("SCHEDULED")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  gym         Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  class_type  ClassType        @relation(fields: [class_type_id], references: [id])
  trainer     Staff?           @relation(fields: [trainer_id], references: [id])
  enrollments ClassEnrollment[]

  @@index([gym_id, scheduled_at(sort: Desc)])
  @@map("class_sessions")
}

model ClassEnrollment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String    @db.Uuid
  session_id   String    @db.Uuid
  member_id    String    @db.Uuid
  status       String    @default("ENROLLED")
  enrolled_at  DateTime  @default(now())
  cancelled_at DateTime?

  gym     Gym          @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  member  Member       @relation(fields: [member_id], references: [id])

  @@unique([session_id, member_id])
  @@index([gym_id, member_id])
  @@map("class_enrollments")
}

// ─── Gamificación ─────────────────────────────────────────────────────────────

model PointsTransaction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  amount       Int      // positivo = ganar, negativo = gastar
  type         String   @db.VarChar(50) // CHECK_IN | WORKOUT_COMPLETE | PR_ACHIEVED | BADGE_UNLOCKED | MANUAL
  description  String?
  reference_id String?  @db.Uuid
  created_at   DateTime @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])

  @@index([gym_id, member_id, created_at(sort: Desc)])
  @@map("points_transactions")
}

model Badge {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String      @db.Uuid
  name            String      @db.VarChar(100)
  description     String?
  icon            String      @default("🏆") @db.VarChar(10)
  condition_type  String      @db.VarChar(50) // CHECKIN_COUNT | WORKOUT_COUNT | PR_COUNT | POINTS_EARNED | STREAK_DAYS
  condition_value Int
  is_active       Boolean     @default(true)
  created_at      DateTime    @default(now())

  gym           Gym           @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member_badges MemberBadge[]

  @@index([gym_id, is_active])
  @@map("badges")
}

model MemberBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id    String   @db.Uuid
  member_id String   @db.Uuid
  badge_id  String   @db.Uuid
  earned_at DateTime @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])
  badge  Badge  @relation(fields: [badge_id], references: [id])

  @@unique([member_id, badge_id])
  @@index([gym_id, member_id])
  @@map("member_badges")
}
