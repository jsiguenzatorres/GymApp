// ─── NUTRICIÓN ────────────────────────────────────────────────────────────────

model NutritionPlan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  name         String   @db.VarChar(200)
  goal         String   @default("MAINTENANCE") @db.VarChar(30) // WEIGHT_LOSS|MUSCLE_GAIN|MAINTENANCE|PERFORMANCE
  kcal_target  Int
  protein_g    Int
  carbs_g      Int
  fat_g        Int
  notes        String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  gym             Gym              @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member          Member           @relation(fields: [member_id], references: [id])
  food_diary_entries FoodDiaryEntry[]

  @@index([gym_id, member_id])
  @@index([gym_id, is_active])
  @@map("nutrition_plans")
}

model FoodItem {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String? @db.Uuid  // null = item global de la biblioteca
  name            String  @db.VarChar(200)
  brand           String? @db.VarChar(100)
  barcode         String? @unique @db.VarChar(50)  // EAN/UPC para escaneo
  kcal_per_100g   Float
  protein_per_100g Float
  carbs_per_100g  Float
  fat_per_100g    Float
  is_verified     Boolean @default(false)
  source          String? @db.VarChar(30)  // 'manual' | 'openfoodfacts' | 'usda'
  created_at      DateTime @default(now())

  gym               Gym?             @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  food_diary_entries FoodDiaryEntry[]

  @@index([gym_id])
  @@index([barcode])
  @@map("food_items")
}

model FoodDiaryEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  plan_id      String?  @db.Uuid
  food_item_id String   @db.Uuid
  date         DateTime @db.Date
  meal_type    String   @default("LUNCH") @db.VarChar(20) // BREAKFAST|LUNCH|DINNER|SNACK
  quantity_g   Float
  kcal         Float
  protein_g    Float
  carbs_g      Float
  fat_g        Float
  notes        String?
  created_at   DateTime @default(now())

  gym       Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member    Member         @relation(fields: [member_id], references: [id])
  plan      NutritionPlan? @relation(fields: [plan_id], references: [id])
  food_item FoodItem       @relation(fields: [food_item_id], references: [id])

  @@index([gym_id, member_id, date(sort: Desc)])
  @@index([gym_id, plan_id])
  @@map("food_diary_entries")
}

// ─── Schedule / Classes ────────────────────────────────────────────────────────

model ClassType {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String         @db.Uuid
  name             String
  description      String?
  color            String         @default("#1d4ed8")
  duration_minutes Int            @default(60)
  difficulty       String?
  is_active        Boolean        @default(true)
  created_at       DateTime       @default(now())

  gym      Gym            @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([gym_id])
  @@map("class_types")
}

model ClassSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id           String    @db.Uuid
  class_type_id    String    @db.Uuid
  trainer_id       String?   @db.Uuid
  scheduled_at     DateTime
  duration_minutes Int
  capacity         Int       @default(20)
  room             String?
  notes            String?
  status           String    @default("SCHEDULED")
  created_at       DateTime  @default(now())
