  class_type  ClassType        @relation(fields: [class_type_id], references: [id])
  trainer     Staff?           @relation(fields: [trainer_id], references: [id])
  enrollments ClassEnrollment[]

  @@index([gym_id, scheduled_at(sort: Desc)])
  @@map("class_sessions")
}

model ClassEnrollment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String    @db.Uuid
  session_id   String    @db.Uuid
  member_id    String    @db.Uuid
  status       String    @default("ENROLLED")
  enrolled_at  DateTime  @default(now())
  cancelled_at DateTime?

  gym     Gym          @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  session ClassSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  member  Member       @relation(fields: [member_id], references: [id])

  @@unique([session_id, member_id])
  @@index([gym_id, member_id])
  @@map("class_enrollments")
}

// ─── Gamificación ─────────────────────────────────────────────────────────────

model PointsTransaction {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id       String   @db.Uuid
  member_id    String   @db.Uuid
  amount       Int      // positivo = ganar, negativo = gastar
  type         String   @db.VarChar(50) // CHECK_IN | WORKOUT_COMPLETE | PR_ACHIEVED | BADGE_UNLOCKED | MANUAL
  description  String?
  reference_id String?  @db.Uuid
  created_at   DateTime @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])

  @@index([gym_id, member_id, created_at(sort: Desc)])
  @@map("points_transactions")
}

model Badge {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id          String      @db.Uuid
  name            String      @db.VarChar(100)
  description     String?
  icon            String      @default("🏆") @db.VarChar(10)
  condition_type  String      @db.VarChar(50) // CHECKIN_COUNT | WORKOUT_COUNT | PR_COUNT | POINTS_EARNED | STREAK_DAYS
  condition_value Int
  is_active       Boolean     @default(true)
  created_at      DateTime    @default(now())

  gym           Gym           @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member_badges MemberBadge[]

  @@index([gym_id, is_active])
  @@map("badges")
}

model MemberBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id    String   @db.Uuid
  member_id String   @db.Uuid
  badge_id  String   @db.Uuid
  earned_at DateTime @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])
  badge  Badge  @relation(fields: [badge_id], references: [id])

  @@unique([member_id, badge_id])
  @@index([gym_id, member_id])
