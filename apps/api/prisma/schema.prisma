// ─── Pipeline de Leads ────────────────────────────────────────────────────────

model Lead {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id              String    @db.Uuid
  first_name          String    @db.VarChar(100)
  last_name           String    @db.VarChar(100)
  email               String?   @db.VarChar(150)
  phone               String?   @db.VarChar(20)
  source              String    @default("OTHER") @db.VarChar(30) // WALK_IN | WEB | REFERRAL | WHATSAPP | INSTAGRAM | FACEBOOK | OTHER
  status              String    @default("NEW") @db.VarChar(20)   // NEW | CONTACTED | INTERESTED | TRIAL | CONVERTED | LOST
  notes               String?
  assigned_to         String?   @db.Uuid // staff_id
  trial_start         DateTime?
  trial_end           DateTime?
  converted_member_id String?   @db.Uuid
  lost_reason         String?   @db.VarChar(200)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  gym      Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  assignee Staff? @relation(fields: [assigned_to], references: [id])

  @@index([gym_id, status])
  @@index([gym_id, created_at(sort: Desc)])
  @@map("leads")
}

// ─── Feedback & NPS ───────────────────────────────────────────────────────────

model Feedback {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id      String   @db.Uuid
  member_id   String   @db.Uuid
  type        String   @default("NPS") @db.VarChar(20)  // NPS | GENERAL | COMPLAINT | SUGGESTION
  nps_score   Int?     // 0–10, solo cuando type = NPS
  category    String?  @db.VarChar(20)                  // PROMOTER | PASSIVE | DETRACTOR (calculado)
  comment     String?
  channel     String   @default("APP") @db.VarChar(20)  // APP | EMAIL | WHATSAPP
  is_resolved Boolean  @default(false)
  resolved_at DateTime?
  resolved_by String?  @db.Uuid // staff_id
  created_at  DateTime @default(now())

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])

  @@index([gym_id, type, created_at(sort: Desc)])
  @@index([gym_id, is_resolved])
  @@map("feedback")
}

// ─── Conversaciones IA (historial multi-turn) ────────────────────────────────

model ConversationSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String   @db.Uuid
  member_id  String   @db.Uuid
  agent_type String   @db.VarChar(10) // ARIA | ZEUS
  messages   Json     @default("[]")  // [{ role, content, ts }]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  gym    Gym    @relation(fields: [gym_id], references: [id], onDelete: Cascade)
  member Member @relation(fields: [member_id], references: [id])

  @@unique([gym_id, member_id, agent_type])
  @@index([gym_id, member_id])
  @@map("conversation_sessions")
}

// ─── Motor Científico ZEUS — Cola de investigación ──────────────────────────

model ResearchQueue {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  abstract_text    String    // resumen/abstract en español (procesado por IA)
  raw_abstract     String?   // texto original del abstract
  authors          String[]
  journal          String    @db.VarChar(200)
  published_date   DateTime? @db.Date
  doi              String?   @db.VarChar(200)
  pubmed_id        String?   @unique @db.VarChar(50)
  keywords         String[]
  source_url       String?

  // Flujo de aprobación (4 niveles)
  approval_level   Int       @default(2)   // 1=IA auto, 2=Admin, 3=Admin+Trainer, 4=Admin+ProfSalud
  status           String    @default("PENDING") @db.VarChar(20) // PENDING|APPROVED|REJECTED|AUTO_APPROVED
  ai_confidence    Float?    // 0.0–1.0 evaluado por Gemini
  ai_assessment    String?   // texto de evaluación de la IA
  reviewed_by      String?   @db.Uuid
  reviewed_at      DateTime?
  rejection_reason String?
  knowledge_id     String?   @db.Uuid  // GymKnowledge creado al aprobar
  embedding        Unsupported("vector(768)")?  // Gemini text-embedding-004

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([status, approval_level])
  @@index([pubmed_id])
  @@map("research_queue")
}

// ─── Base de conocimiento del gym (RAG) ──────────────────────────────────────

model GymKnowledge {
  id         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gym_id     String                     @db.Uuid
  content    String
  embedding  Unsupported("vector(768)")?
  type       String                     @db.VarChar(30) // FAQ | POLICY | EXERCISE | PRODUCT | STAFF | SCHEDULE
  source     String?                    @db.VarChar(100)
  is_active  Boolean                    @default(true)
  created_at DateTime                   @default(now())

  gym Gym @relation(fields: [gym_id], references: [id], onDelete: Cascade)

  @@index([gym_id, type])
  @@map("gym_knowledge")
}

// ─── Plan Fundadores (oferta única de lanzamiento) ───────────────────────────
// Singleton: solo debe existir UNA fila con key='default'.
// Tracking de cupos para precio congelado de por vida a los primeros 50 gyms.

model FounderOffer {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key                   String   @unique @default("default") @db.VarChar(50)
  total_slots           Int      @default(50)
  starter_price         Decimal  @default(59.00) @db.Decimal(10, 2)
  pro_price             Decimal  @default(99.00) @db.Decimal(10, 2)
  elite_price           Decimal  @default(199.00) @db.Decimal(10, 2)
  regular_starter_price Decimal  @default(79.00) @db.Decimal(10, 2)
  regular_pro_price     Decimal  @default(149.00) @db.Decimal(10, 2)
  regular_elite_price   Decimal  @default(299.00) @db.Decimal(10, 2)
  active                Boolean  @default(true)
  deadline_at           DateTime?
  free_months           Int      @default(3)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("founder_offers")
}

// ─── Fotos de progreso del miembro (antes/después) ───────────────────────────

model ProgressPhoto {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id  String   @db.Uuid
  url        String
  category   String   @default("FRONT") @db.VarChar(20) // FRONT | SIDE | BACK | CUSTOM
  weight_kg  Decimal? @db.Decimal(5, 2)
  note       String?
  taken_at   DateTime @default(now())
  created_at DateTime @default(now())

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id, taken_at(sort: Desc)])
  @@map("progress_photos")
}

// ─── Add-ons del miembro (suscripciones adicionales: NUTRITION, etc.) ────────
// Modelo flexible: un miembro puede tener varios tipos de add-ons activos.
// Solo UNO activo por (member, type) — el último update gana.

model MemberAddon {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id           String    @db.Uuid
  type                String    @db.VarChar(20) // NUTRITION | (futuro: COACHING, MENTAL, etc.)
  tier                String    @db.VarChar(20) // BASIC | PRO | ELITE
  status              String    @default("ACTIVE") @db.VarChar(20) // ACTIVE | CANCELLED | EXPIRED
  starts_at           DateTime  @default(now())
  ends_at             DateTime?
  price_paid          Decimal?  @db.Decimal(8, 2)
  currency            String    @default("USD") @db.VarChar(3)
  assigned_by_staff_id String?  @db.Uuid // staff que activó manualmente (null si fue compra Stripe/MP)
  cancellation_reason String?
  notes               String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id, type, status])
  @@map("member_addons")
}

// ─── Datos de salud del miembro (peso, agua, sueño, pasos) ─────────────────
// Diseñado para soportar tanto registro manual del miembro como pull desde
// HealthKit (iOS) / Health Connect (Android) cuando se haga build nativo.

model HealthDataEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id   String   @db.Uuid
  kind        String   @db.VarChar(20) // WEIGHT | WATER | SLEEP | STEPS | HEART_RATE | HRV
  value       Decimal  @db.Decimal(10, 2)
  unit        String   @db.VarChar(10) // kg | ml | min | count | bpm | ms
  recorded_at DateTime
  source      String   @default("manual") @db.VarChar(20) // manual | apple_health | google_fit | wearable
  notes       String?
  created_at  DateTime @default(now())

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@index([member_id, kind, recorded_at(sort: Desc)])
  @@map("health_data_entries")
}

// ─── Preferencias de notificaciones del miembro ─────────────────────────────
// Soporta recordatorios de comidas, agua, entreno, etc. La activación real
// se hace via BullMQ scheduler que corre cada hora (Fase 2 de implementación).

model NotificationPreference {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  member_id   String   @db.Uuid
  kind        String   @db.VarChar(30) // MEAL_REMINDER_BREAKFAST | ..._LUNCH | ..._DINNER
                                       // WATER_HOURLY | WORKOUT_REMINDER | STREAK_AT_RISK
  enabled     Boolean  @default(true)
  time_of_day String?  @db.VarChar(5)  // "HH:mm" para recordatorios horarios
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  member Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@unique([member_id, kind])
  @@map("notification_preferences")
}
