# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/gymapp_dev"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_64_CHARS_MIN"
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_FROM_JWT_SECRET"

# ── Encriptación (2FA secrets) ────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="CHANGE_ME_32_CHARS_MIN"

# ── Puerto del servidor ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Redis (para cache — Sprint 1.3+) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

