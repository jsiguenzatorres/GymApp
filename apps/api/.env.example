# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/gymapp_dev"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_64_CHARS_MIN"
JWT_REFRESH_SECRET="CHANGE_ME_DIFFERENT_FROM_JWT_SECRET"

# ── Encriptación (2FA secrets) ────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="CHANGE_ME_32_CHARS_MIN"

# ── Puerto del servidor ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Redis (para cache — Sprint 1.3+) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Email (Sprint 1.6) ────────────────────────────────────────────────────────
# SENDGRID_API_KEY=""
# FROM_EMAIL="noreply@gymapp.app"

# ── Pagos (Sprint 1.3) ────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# MERCADOPAGO_ACCESS_TOKEN=""

# ── Gemini (IA principal — ARIA, ZEUS, Business Coach, Nutrición IA) ─────────
# Se soportan varias keys con rotación automática si una se queda sin cuota
# GEMINI_API_KEY1=""
# GEMINI_API_KEY2=""

# ── NVIDIA NIM (respaldo de emergencia si Gemini falla — ver
# docs/INVESTIGACION_MODELOS_IA_NVIDIA.md) ────────────────────────────────────
# Obtener key gratuita en https://build.nvidia.com (crear cuenta → "Try API")
# NVIDIA_NIM_API_KEY=""
# NVIDIA_NIM_MODEL="google/gemma-4-31b-it"          # opcional, nivel 2 (rápido)
# NVIDIA_NIM_TERTIARY_MODEL="qwen/qwen3.5-397b-a17b" # opcional, nivel 3 (último recurso)
